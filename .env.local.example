# ─────────────────────────────────────────────────────────────────────────────
# Ida Designer — Environment Variables
#
# HOW TO USE:
#   1. Copy this file: cp .env.local.example .env.local
#   2. Fill in the values from your Supabase project dashboard
#   3. NEVER commit .env.local to git — it contains secrets
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase — public values (safe to expose in the browser) ─────────────────
# Found in: Supabase Dashboard → Project Settings → API → Project URL / anon key

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...


# ── Supabase — server-only secrets (NEVER add NEXT_PUBLIC_ prefix) ───────────

# Service role key — bypasses RLS, has full database access.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# Used by: /api/setup route to create the super admin user
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Direct database connection (for migrations / psql access only)
# Password note: the @ in the password must be encoded as %40 in the URL
DATABASE_URL=postgresql://postgres:YourPassword%40here@db.your-project-ref.supabase.co:5432/postgres


# ── App secrets ──────────────────────────────────────────────────────────────

# Secret key for the one-time /api/setup admin endpoint.
# Choose any strong random string — keep it private.
SETUP_KEY=change-me-to-something-random


# ── Third-party services (server-only) ───────────────────────────────────────

# Anthropic API key — if you add AI features later
ANTHROPIC_API_KEY=sk-ant-...your-key...
